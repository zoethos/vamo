# Secrets
.env
*.env.local
tool/rls-smoke.local.ps1

# Service-account / credential keys — NEVER commit. Canonical home is the
# Supabase secret store / Vault, never on disk in the repo.
*-adminsdk-*.json
*service-account*.json
*serviceaccount*.json
*-credentials*.json
secrets/
*.pem
*.p8
*.p12
*.key

# Android release signing — keystore + passwords stay local, never in the repo
key.properties
*.jks
*.keystore

# npm (supabase CLI dev-dependency)
node_modules/

# Dart / Flutter
.dart_tool/
.packages
.pub-cache/
.pub/
build/
.flutter-plugins
.flutter-plugins-dependencies
# Lockfiles: commit app/ + root pubspec.lock (reproducible builds + vuln scan);
# ignore internal package locks — they resolve via the app. See docs/SECURITY_PATCHING.md §12.
packages/*/pubspec.lock
Vamo/app/pubspec.lock

# Generated code
*.g.dart
*.freezed.dart
*.gr.dart

# Melos
.melos_tool/

# IDE / OS
.idea/
.vscode/
*.iml
.DS_Store

# Supabase local
supabase/.branches/
supabase/.temp/

# Flutter test failure artifacts
**/test/failures/

# Lock files left by office apps
.~lock.*#

# Temporary: leftover locked by a tool session - delete folder, then remove this line
/Vamo/
app/flutter_*.png
