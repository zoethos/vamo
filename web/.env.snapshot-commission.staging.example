# Trusted snapshot commission worker only. Copy to web/.env.snapshot-commission.staging.local.
# Use the Confluendo staging FSQ service key and the Confluendo Control staging owner DSN.
# Never commit real values.
INGESTION_CONTROL_DATABASE_URL=<staging-owner-postgres-connection-string>
FSQ_OS_PLACES_CATALOG_SERVICE_API_KEY=<ConfluendoOsPlacesCatalogStagingWorker-key>
