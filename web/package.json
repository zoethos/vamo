{
  "name": "vamo-web",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "postcss": "8.5.10"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "ingestion:docker": "docker compose -f ../tool/ingestion/docker-compose.yml up --build",
    "ingestion:docker:down": "docker compose -f ../tool/ingestion/docker-compose.yml down",
    "ingestion:worker": "npm --workspace @vamo/ingestion-platform run build && npm --workspace @vamo/ingestion-platform run worker",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "^2.10.0",
    "typescript": "^5.4.0"
  }
}
