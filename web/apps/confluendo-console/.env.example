# Copy to .env.local for local Confluendo console dev. Vercel: set the same
# keys in the Confluendo console project env.
#
# A single production workspace can use the legacy variables below. For the
# switchable Staging / Production console, configure the prefixed variables
# listed after this legacy block instead. Never add a database URL as
# NEXT_PUBLIC_*.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_POSTHOG_API_KEY=phc_your_project_key
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Server-only ingestion control API. Never expose these as NEXT_PUBLIC_*.
INGESTION_CONTROL_DATABASE_URL=postgres://user:password@host:5432/database
INGESTION_ADMIN_API_TOKEN=replace-with-a-long-random-admin-token

# Server-only. Vamo place-intelligence cache DB for dashboard cache metrics.
# Optional: when unset, cache stat cards render as zero (operational data still
# loads from the control DB). Never expose as NEXT_PUBLIC_*.
VAMO_PLACE_CACHE_DATABASE_URL=postgres://user:password@host:5432/database

# Optional dual-control-workspace configuration. When both profiles are
# configured, the masthead selector switches Supabase Auth and the control DB
# together. The browser receives only the selected Supabase URL and anon key.
CONFLUENDO_CONTROL_DEFAULT_ENVIRONMENT=production
CONFLUENDO_CONTROL_STAGING_SUPABASE_URL=https://YOUR_STAGING_PROJECT.supabase.co
CONFLUENDO_CONTROL_STAGING_SUPABASE_ANON_KEY=your-staging-anon-key
CONFLUENDO_CONTROL_STAGING_DATABASE_URL=postgres://user:password@host:5432/database
CONFLUENDO_CONTROL_PRODUCTION_SUPABASE_URL=https://YOUR_PRODUCTION_PROJECT.supabase.co
CONFLUENDO_CONTROL_PRODUCTION_SUPABASE_ANON_KEY=your-production-anon-key
CONFLUENDO_CONTROL_PRODUCTION_DATABASE_URL=postgres://user:password@host:5432/database

# Production-only Vamo boundary credentials. Do not configure these for the
# Staging workspace. They remain server-only and are never sent to the browser.
CONFLUENDO_CONTROL_PRODUCTION_VAMO_PLACE_CACHE_DATABASE_URL=postgres://user:password@host:5432/database
CONFLUENDO_CONTROL_PRODUCTION_VAMO_PRODUCTION_INBOX_TELEMETRY_DATABASE_URL=postgres://user:password@host:5432/database
CONFLUENDO_CONTROL_PRODUCTION_VAMO_PRODUCTION_INBOX_APPLY_DATABASE_URL=postgres://user:password@host:5432/database
CONFLUENDO_CONTROL_PRODUCTION_VAMO_PRODUCTION_INBOX_WRITER_DATABASE_URL=postgres://user:password@host:5432/database
CONFLUENDO_CONTROL_PRODUCTION_VAMO_PRODUCTION_INBOX_ENVIRONMENT=production
CONFLUENDO_CONTROL_PRODUCTION_INGESTION_ADMIN_API_TOKEN=replace-with-a-long-random-admin-token
