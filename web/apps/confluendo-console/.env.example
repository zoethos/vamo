# Copy to .env.local for local Confluendo console dev. Vercel: set the same
# keys in the Confluendo console project env.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_POSTHOG_API_KEY=phc_your_project_key
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Server-only ingestion control API. Never expose these as NEXT_PUBLIC_*.
INGESTION_CONTROL_DATABASE_URL=postgres://user:password@host:5432/database
INGESTION_ADMIN_API_TOKEN=replace-with-a-long-random-admin-token

# Server-only. Vamo place-intelligence cache DB for dashboard cache metrics.
# Optional: when unset, cache stat cards render as zero (operational data still
# loads from the control DB). Never expose as NEXT_PUBLIC_*.
VAMO_PLACE_CACHE_DATABASE_URL=postgres://user:password@host:5432/database
