{
  "name": "@confluendo/ingestion-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./adapters/source": "./dist/adapters/source/src/index.js",
    "./adapters/target": "./dist/adapters/target/src/index.js",
    "./adapters/target/postgres": "./dist/adapters/target/src/postgres-dry-run.js",
    "./adapters/target/supabase": "./dist/adapters/target/src/supabase-postgres.js",
    "./adapters/target/staging-canary": "./dist/adapters/target/src/postgres-staging-canary.js",
    "./adapters/target/production-inbox": "./dist/adapters/target/src/postgres-production-inbox.js",
    "./core": "./dist/core/src/index.js",
    "./control-api": {
      "types": "./dist/core/src/control-command-api.d.ts",
      "default": "./dist/core/src/control-command-api.js"
    },
    "./admin-auth": {
      "types": "./dist/core/src/admin-auth.d.ts",
      "default": "./dist/core/src/admin-auth.js"
    },
    "./read-model": {
      "types": "./dist/core/src/read-model.d.ts",
      "default": "./dist/core/src/read-model.js"
    },
    "./progressive-read-model": {
      "types": "./dist/core/src/progressive-read-model.d.ts",
      "default": "./dist/core/src/progressive-read-model.js"
    },
    "./control-read": {
      "types": "./dist/core/src/control-read.d.ts",
      "default": "./dist/core/src/control-read.js"
    },
    "./progressive-control-read": {
      "types": "./dist/core/src/progressive-control-read.d.ts",
      "default": "./dist/core/src/progressive-control-read.js"
    },
    "./batch-queue-control-read": {
      "types": "./dist/core/src/batch-queue-control-read.d.ts",
      "default": "./dist/core/src/batch-queue-control-read.js"
    },
    "./batch-queue-mutations": {
      "types": "./dist/core/src/batch-queue-mutations.d.ts",
      "default": "./dist/core/src/batch-queue-mutations.js"
    },
    "./staging-canary-control": {
      "types": "./dist/core/src/staging-canary-control.d.ts",
      "default": "./dist/core/src/staging-canary-control.js"
    },
    "./production-inbox-control": {
      "types": "./dist/core/src/production-inbox-control.d.ts",
      "default": "./dist/core/src/production-inbox-control.js"
    },
    "./policy": "./dist/policy/src/index.js",
    "./spec": "./dist/spec/src/index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "import:contract": "npm run build && node scripts/import-consumer-contract.mjs",
    "ip15:boundary-audit": "node scripts/ip15-boundary-audit.mjs",
    "ip14:dry-run": "npm run build && node scripts/run-ip14-dry-run.mjs",
    "ip16:staging-canary": "npm run build && node scripts/run-ip16-staging-canary.mjs",
    "ip17:production-inbox": "npm run build && node scripts/run-ip17-production-inbox.mjs",
    "ip18:batch-plan": "npm run build && node scripts/run-ip18-batch-plan.mjs",
    "ip18:batch-queue-seed": "npm run build && node scripts/run-ip18-batch-queue-seed.mjs",
    "test": "npm run build && node scripts/run-spec-tests.mjs",
    "worker": "node dist/core/src/worker-main.js"
  },
  "dependencies": {
    "pg": "8.22.0",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "typescript": "^5.7.0"
  }
}
