# Trusted snapshot commission worker only. Copy to web/.env.snapshot-commission.production.local.
# Use the Confluendo production FSQ service key and the Confluendo Control production owner DSN.
# Never commit real values.
INGESTION_CONTROL_DATABASE_URL=<production-owner-postgres-connection-string>
FSQ_OS_PLACES_CATALOG_SERVICE_API_KEY=<ConfluendoOsPlacesCatalogProductionWorker-key>
