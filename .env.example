# Copy to .env and fill in. Never commit .env or service-role keys.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
POSTHOG_API_KEY=your-posthog-project-key
# Optional — EU: https://eu.i.posthog.com
POSTHOG_HOST=https://us.i.posthog.com
# FX: free key from https://exchangerate.host (required for direct client fallback)
EXCHANGERATE_ACCESS_KEY=your-exchangerate-host-key
# Optional edge proxy — set the same key as a Supabase secret on fx-rates
FX_RATES_FUNCTION_URL=https://YOUR_PROJECT.functions.supabase.co/fx-rates
